    {
      "id": 10,
      "type": "timeseries",
      "title": "Rede — Bytes Recebidos/s",
      "description": "",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "refId": "A",
          "legendFormat": "{{instance}} - {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Uptime Backend",
      "description": "",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{job=\"node-exporter-backend\"}",
          "refId": "A",
          "legendFormat": "Uptime"
