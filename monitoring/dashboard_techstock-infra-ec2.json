    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU por Instância (histórico)",
      "description": "",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "round(100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100), 0.1)",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RAM Total vs Disponível",
      "description": "",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes / 1073741824",
          "refId": "A",
          "legendFormat": "RAM Total"
        },
        {
          "expr": "node_memory_MemAvailable_bytes / 1073741824",
          "refId": "B",
          "legendFormat": "RAM Disponível"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "Disco Usado Backend (%)",
      "description": "",
      "gridPos": { "x": 0, "y": 15, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "round((1 - node_filesystem_free_bytes{job=\"node-exporter-backend\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node-exporter-backend\",mountpoint=\"/\"}) * 100, 0.1)",
