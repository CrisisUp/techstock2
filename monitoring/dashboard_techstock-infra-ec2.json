{
  "uid": "techstock-infra-ec2",
  "title": "TechStock — Infraestrutura EC2",
  "tags": ["techstock", "ec2", "infra"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## 🖥️ Infraestrutura EC2 — Backend e Monitoring\nMétricas do sistema operacional coletadas via **node_exporter** (porta 9100)."
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "CPU Backend (%)",
      "description": "",
      "gridPos": { "x": 0, "y": 2, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "round(100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter-backend\",mode=\"idle\"}[1m])) * 100), 0.1)",
          "refId": "A",
          "legendFormat": "CPU Backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "RAM Backend Livre (GB)",
      "description": "",
      "gridPos": { "x": 6, "y": 2, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter-backend\"} / 1073741824",
          "refId": "A",
          "legendFormat": "RAM Livre"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CPU Monitoring (%)",
      "description": "",
      "gridPos": { "x": 12, "y": 2, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "round(100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter-monitoring\",mode=\"idle\"}[1m])) * 100), 0.1)",
          "refId": "A",
          "legendFormat": "CPU Monitoring"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "RAM Monitoring Livre (GB)",
      "description": "",
      "gridPos": { "x": 18, "y": 2, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter-monitoring\"} / 1073741824",
          "refId": "A",
          "legendFormat": "RAM Livre"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
