{
  "uid": "techstock-api",
  "title": "TechStock API — Visão Geral",
  "tags": ["techstock", "api", "nodejs"],
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## 🚀 TechStock API — Monitoramento em Tempo Real\nDashboard personalizado para a aplicação Node.js. Métricas coletadas via **prom-client** no endpoint `/metrics`."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requisições/s (últimos 5min)",
      "description": "Taxa total de requisições HTTP por segundo",
      "gridPos": { "x": 0, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(techstock_http_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "Total req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Taxa de Erros 5xx (%)",
      "description": "Percentual de respostas com erro 5xx. Acima de 5% = alerta crítico",
      "gridPos": { "x": 6, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(techstock_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(techstock_http_requests_total[5m])) * 100",
          "refId": "A",
          "legendFormat": "Erro 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Heap Node.js Usado (%)",
      "description": "% do heap V8 em uso. Acima de 85% = possível memory leak",
      "gridPos": { "x": 12, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "techstock_nodejs_heap_size_used_bytes / techstock_nodejs_heap_size_total_bytes * 100",
          "refId": "A",
          "legendFormat": "Heap usado"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Event Loop Lag p99 (ms)",
      "description": "Latência do event loop no percentil 99. Alto = CPU saturada",
      "gridPos": { "x": 18, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "techstock_nodejs_eventloop_lag_p99_seconds * 1000",
          "refId": "A",
          "legendFormat": "Lag p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requisições HTTP por Status",
      "description": "Distribuição por código HTTP (200, 201, 400, 404, 500...)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(status) (rate(techstock_http_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Heap Histórico (bytes)",
      "description": "Crescimento do heap ao longo do tempo. Tendência crescente = leak",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "techstock_nodejs_heap_size_used_bytes",
          "refId": "A",
          "legendFormat": "Heap usado"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Top 5 Rotas mais Acessadas",
      "description": "Rotas com maior tráfego — identifica gargalos",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(5, sum by(path) (rate(techstock_http_requests_total[5m])))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Requisições por Rota",
      "description": "Distribuição de tráfego por endpoint",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(path) (rate(techstock_http_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC — Tempo de Coleta (s/s)",
      "description": "Tempo gasto em Garbage Collection. Alto = app consumindo muita memória",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(techstock_nodejs_gc_duration_seconds_sum[5m])",
          "refId": "A",
          "legendFormat": "GC time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active Handles & Requests",
      "description": "Handles ativos (conexões, timers, sockets). Crescimento = leak de recursos",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "techstock_nodejs_active_handles",
          "refId": "A",
          "legendFormat": "Active Handles"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memória Externa (bytes)",
      "description": "Memória alocada fora do heap V8 (Buffers, native addons)",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "techstock_nodejs_external_memory_bytes",
          "refId": "A",
          "legendFormat": "Memória Externa"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    }
  ],
  "schemaVersion": 27,
  "version": 1
}