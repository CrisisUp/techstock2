# ══════════════════════════════════════════════════════════════════════════════
# TechStock - Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════════════════
#
# Como usar:
#   1. Copie este arquivo para .env
#   2. Ajuste as variáveis conforme seu ambiente
#   3. NUNCA commite o .env no repositório!
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta onde a API vai rodar
PORT=3000

# Ambiente (development, production, test)
NODE_ENV=development

# ── AWS Secrets Manager (Opcional) ────────────────────────────────────────────
# Nome do secret no AWS Secrets Manager
# Se não configurado, usa variáveis de ambiente diretamente
# TECHSTOCK_SECRET_NAME=techstock/prod/db-credentials
# AWS_REGION=us-east-1

# ── PostgreSQL / RDS ──────────────────────────────────────────────────────────
# Configurações de conexão com o banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techstock
DB_USER=techstock_user

# ⚠️ IMPORTANTE: Use uma senha forte em produção!
# Recomendação: 16+ caracteres com letras, números e símbolos
DB_PASSWORD=ChangeMeToAStrongPassword123!@#

# SSL do banco de dados (true/false)
# Em produção com RDS, geralmente é true
DB_SSL=false

# ── Pool de Conexões ──────────────────────────────────────────────────────────
# Mínimo de conexões mantidas no pool
DB_POOL_MIN=2

# Máximo de conexões no pool
# Ajuste conforme a carga esperada (padrão: 20 para produção)
DB_POOL_MAX=10

# Timeout para aquisição de conexão (milissegundos)
DB_CONNECTION_TIMEOUT=5000

# Timeout para conexões ociosas (milissegundos)
DB_IDLE_TIMEOUT=30000

# ── Segurança ─────────────────────────────────────────────────────────────────
# API Key para autenticação (deixe vazio para desabilitar)
# ⚠️ Em produção, SEMPRE configure uma API Key forte!
# Gerar: openssl rand -base64 32
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula)
# Use "*" para permitir todas (apenas desenvolvimento)
# Exemplo em produção: https://meu-sistema.com,https://admin.meu-sistema.com
CORS_ORIGIN=*

# ── Logging ──────────────────────────────────────────────────────────────────
# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# ── Rate Limiting (Opcional) ─────────────────────────────────────────────────
# Proteção contra múltiplas requisições
# Descomente para ativar (requer instalação do express-rate-limit)
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
# RATE_LIMIT_MAX_REQUESTS=100    # Máximo de requisições por janela

# ══════════════════════════════════════════════════════════════════════════════
# EXEMPLOS DE CONFIGURAÇÃO
# ══════════════════════════════════════════════════════════════════════════════

# ── Desenvolvimento Local ─────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PASSWORD=dev_password
# NODE_ENV=development
# CORS_ORIGIN=*
# LOG_LEVEL=debug

# ── Produção (RDS + ALB) ─────────────────────────────────────────────────────
# DB_HOST=techstock-database.xxxxxx.us-east-1.rds.amazonaws.com
# DB_PASSWORD=SuperStrongPassword123!@#456
# DB_SSL=true
# NODE_ENV=production
# CORS_ORIGIN=http://techstock-alb-123456789.us-east-1.elb.amazonaws.com
# API_KEY=$(openssl rand -base64 32)
# LOG_LEVEL=warn
# DB_POOL_MIN=5
# DB_POOL_MAX=20

# ── AWS Secrets Manager (Recomendado para produção) ──────────────────────────
# TECHSTOCK_SECRET_NAME=techstock/prod/db-credentials
# AWS_REGION=us-east-1
# DB_HOST=  # Será carregado do Secrets Manager
# DB_PASSWORD=  # Será carregado do Secrets Manager
# ... outras variáveis serão carregadas do Secrets Manager