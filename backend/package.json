{
  "name": "techstock",
  "version": "1.0.0",
  "description": "Sistema de controle de estoque com PostgreSQL, monitoramento Prometheus e segurança aprimorada",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:debug": "node --inspect --watch server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo 'No build step required'",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.654.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "plugin:jest/recommended",
      "prettier"
    ],
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "node/no-unsupported-features/es-syntax": "off"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server.js",
      "src/**/*.js",
      "!**/node_modules/**",
      "!**/tests/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seu-usuario/techstock.git"
  },
  "keywords": [
    "estoque",
    "inventory",
    "postgresql",
    "express",
    "prometheus",
    "monitoring"
  ],
  "author": "Seu Nome <seu-email@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seu-usuario/techstock/issues"
  },
  "homepage": "https://github.com/seu-usuario/techstock#readme"
}
